@model List<HotelSol.Models.Producto>

@{
    ViewData["Title"] = "Productos";
}

<h4 class="mb-3">Lista de Productos</h4>

<div class="card shadow">
    <div class="card-header bg-primary text-white d-flex justify-content-between">
        <span>Productos</span>

        <button class="btn btn-success btn-sm" onclick="abrirModal()">
            Crear Nuevo
        </button>
    </div>

    <div class="card-body">

        <table class="table table-bordered table-hover">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Detalle</th>
                    <th>Precio</th>
                    <th>Cantidad</th>
                    <th>Estado</th>
                    <th style="width:120px;"></th>
                </tr>
            </thead>

            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@p.Nombre</td>
                        <td>@p.Detalle</td>
                        <td>@((p.Precio ?? 0).ToString("0.00"))</td>
                        <td>@(p.Cantidad ?? 0)</td>
                        <td>
                            @if (p.Estado == true)
                            {
                                <span class="badge badge-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge badge-danger">Inactivo</span>
                            }
                        </td>

                        <td>
                            <button class="btn btn-primary btn-sm"
                                    onclick="editar(@p.IdProducto)">
                                <i class="fa-solid fa-file-pen"></i>
                            </button>

                            <button class="btn btn-danger btn-sm"
                                    onclick="eliminar(@p.IdProducto)">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>
     


</div>

<div class="modal fade" id="modalProducto">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5>Producto</h5>
                <button class="close" data-dismiss="modal">&times;</button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="IdProducto" />

                <div class="form-group">
                    <label>Nombre</label>
                    <input id="Nombre" class="form-control" />
                </div>

                <div class="form-group">
                    <label>Detalle</label>
                    <input id="Detalle" class="form-control" />
                </div>

                <div class="form-group">
                    <label>Precio</label>
                    <input id="Precio" type="text" class="form-control" />
                </div>

                <div class="form-group">
                    <label>Cantidad</label>
                    <input id="Cantidad" type="number" class="form-control" />
                </div>

            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                <button class="btn btn-primary" onclick="guardar()">Guardar</button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>

        function abrirModal(){
            limpiar();
            $("#modalProducto").modal("show");
        }

        function limpiar(){
            $("#IdProducto").val(0);
            $("#Nombre").val("");
            $("#Detalle").val("");
            $("#Precio").val("");
            $("#Cantidad").val("");
        }

        function guardar(){

            if (!$("#Nombre").val()) {
                alert("El nombre es obligatorio");
                return;
            }

            let data = {
                IdProducto: $("#IdProducto").val(),
                Nombre: $("#Nombre").val(),
                Detalle: $("#Detalle").val(),
                Precio: $("#Precio").val().replace(",", "."),
                Cantidad: $("#Cantidad").val()
            };

            $.post("/Tienda/GuardarProducto", data, function(res){
                if(res.ok){
                    location.reload();
                }
            });
        }

        function editar(id){

            $.get("/Tienda/ObtenerProducto?id=" + id, function(data){

                $("#IdProducto").val(data.idProducto);
                $("#Nombre").val(data.nombre);
                $("#Detalle").val(data.detalle);
                $("#Precio").val(data.precio);
                $("#Cantidad").val(data.cantidad);

                $("#modalProducto").modal("show");
            });
        }

        function eliminar(id){

            if(!confirm("Eliminar producto?")) return;

            $.post("/Tienda/EliminarProducto", { id }, function(){
                location.reload();
            });
        }

    </script>
}
