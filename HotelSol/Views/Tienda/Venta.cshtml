@model HotelSol.Models.ViewModels.TiendaVentaVM

@{
    ViewData["Title"] = "Venta";
}

<h4 class="mb-3">Detalle Venta</h4>

<!-- 🔷 RESUMEN -->
<div class="card mb-3">
    <div class="card-body">

        <div class="row">
            <div class="col-md-3">
                <strong>Número:</strong>
                <div>@Model.NumeroHabitacion</div>
            </div>

            <div class="col-md-3">
                <strong>Cliente:</strong>
                <div>@Model.Cliente</div>
            </div>

            <div class="col-md-3">
                <strong>Documento:</strong>
                <div>@Model.Documento</div>
            </div>

            <div class="col-md-3">
                <strong>Fecha Entrada:</strong>
                <div>@Model.FechaEntrada?.ToString("dd/MM/yyyy")</div>
            </div>
        </div>

    </div>
</div>

<!-- 🔥 FORMULARIO -->
<form id="formVenta" asp-controller="Tienda" asp-action="FinalizarVenta" method="post">

    @Html.AntiForgeryToken()

    <input type="hidden" name="IdRecepcion" value="@Model.IdRecepcion" />
    <input type="hidden" id="detalleJson" name="detalleJson" />

    <div class="card">
        <div class="card-body">

            <div class="row mb-3">

                <div class="col-md-4">
                    <label>Producto</label>
                    <select id="producto" class="form-control">
                        @foreach (var p in Model.Productos)
                        {
                            <option value="@p.IdProducto" data-precio="@p.Precio">
                                @p.Nombre
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label>Precio</label>
                    <input type="text" id="precio" class="form-control" readonly />
                </div>

                <div class="col-md-2">
                    <label>Cantidad</label>
                    <input type="number" id="cantidad" value="1" class="form-control" />
                </div>

                <div class="col-md-3 d-flex align-items-end">
                    <button type="button" class="btn btn-success w-100" onclick="agregar()">
                        Agregar
                    </button>
                </div>

            </div>

            <!-- TABLA -->
            <table class="table table-bordered" id="tabla">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Cantidad</th>
                        <th>Precio</th>
                        <th>SubTotal</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>

            <!-- TOTAL -->
            <div class="text-right">
                <h5>Total: <span id="total">0.00</span></h5>
            </div>

            <div class="text-right mt-3">
                <button type="submit" class="btn btn-primary">
                    Finalizar Venta
                </button>
            </div>

        </div>
    </div>

</form>

<script>

    let detalles = []; // 🔥 GLOBAL

    document.addEventListener("DOMContentLoaded", function () {

        console.log("🔥 SCRIPT CARGADO");

        let total = 0;

        const producto = document.getElementById("producto");
        const precioInput = document.getElementById("precio");
        const form = document.getElementById("formVenta"); // 🔥 USAMOS ID

        // 🔹 CAMBIO DE PRODUCTO → ACTUALIZA PRECIO
        producto.addEventListener("change", function () {
            let precio = this.selectedOptions[0].dataset.precio;
            precioInput.value = parseFloat(precio).toFixed(2);
        });

        // 🔹 PRECIO INICIAL
        producto.dispatchEvent(new Event("change"));

        // 🔹 AGREGAR PRODUCTO
        window.agregar = function () {

            console.log("➕ AGREGAR CLICK");

            let select = document.getElementById("producto");
            let idProducto = parseInt(select.value);
            let nombre = select.options[select.selectedIndex].text;
            let precio = parseFloat(select.selectedOptions[0].dataset.precio);
            let cantidad = parseInt(document.getElementById("cantidad").value);

            if (!cantidad || cantidad <= 0) {
                alert("Cantidad inválida");
                return;
            }

            let subtotal = precio * cantidad;

            // 🔥 GUARDAR EN ARRAY
            detalles.push({
                idProducto: idProducto,
                cantidad: cantidad,
                precio: precio,
                subTotal: subtotal
            });

            // 🔹 AGREGAR FILA A TABLA
            let fila = `
                <tr>
                    <td>${nombre}</td>
                    <td>${cantidad}</td>
                    <td>${precio.toFixed(2)}</td>
                    <td>${subtotal.toFixed(2)}</td>
                </tr>
            `;

            document.querySelector("#tabla tbody").innerHTML += fila;

            // 🔹 ACTUALIZAR TOTAL
            total += subtotal;
            document.getElementById("total").innerText = total.toFixed(2);
        };

        // 🔥 SUBMIT DEL FORM
        if (form) {
            form.onsubmit = function (e) {

                console.log("🔥 CLICK FINALIZAR");

                if (detalles.length === 0) {
                    alert("Debes agregar al menos un producto");
                    e.preventDefault();
                    return false;
                }

                // 🔥 ENVIAR JSON AL CONTROLLER
                document.getElementById("detalleJson").value = JSON.stringify(detalles);

                console.log("📦 ENVIANDO:", detalles);

                return true;
            };
        }

    });

</script>

