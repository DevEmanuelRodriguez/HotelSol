@model HotelSol.Models.ViewModels.TiendaVentaVM

@{
    ViewData["Title"] = "Venta";
}

<h4 class="mb-3">Detalle Venta</h4>

<!-- RESUMEN -->
<div class="card mb-3">
    <div class="card-body">

        <div class="row">
            <div class="col-md-3">
                <strong>Número:</strong>
                <div>@Model.NumeroHabitacion</div>
            </div>

            <div class="col-md-3">
                <strong>Cliente:</strong>
                <div>@Model.Cliente</div>
            </div>

            <div class="col-md-3">
                <strong>Documento:</strong>
                <div>@Model.Documento</div>
            </div>

            <div class="col-md-3">
                <strong>Fecha Entrada:</strong>
                <div>@Model.FechaEntrada?.ToString("dd/MM/yyyy")</div>
            </div>
        </div>

    </div>
</div>

<!-- FORMULARIO -->
<form id="formVenta" asp-controller="Tienda" asp-action="FinalizarVenta" method="post">

    @Html.AntiForgeryToken()

    <input type="hidden" name="IdRecepcion" value="@Model.IdRecepcion" />
    <input type="hidden" id="detalleJson" name="detalleJson" />

    <div class="card">
        <div class="card-body">

            <div class="row mb-3">

                <div class="col-md-3">
                    <label>Producto</label>
                    <select id="producto" class="form-control">
                        @foreach (var p in Model.Productos)
                        {
                            <option value="@p.IdProducto"
                                    data-precio="@((p.Precio ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture))"
                                    data-stock="@(p.Cantidad ?? 0)">
                                @p.Nombre
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label>Precio</label>
                    <input type="text" id="precio" class="form-control" readonly />
                </div>

                <div class="col-md-2">
                    <label>Stock disponible</label>
                    <input type="text" id="stock" class="form-control" readonly />
                </div>

                <div class="col-md-2">
                    <label>Cantidad</label>
                    <input type="number" id="cantidad" value="1" class="form-control" />
                </div>

                <div class="col-md-2 d-flex align-items-end">
                    <button type="button" class="btn btn-success w-100" onclick="agregar()">
                        Agregar
                    </button>
                </div>

            </div>

            <!-- TABLA -->
            <table class="table table-bordered" id="tabla">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th style="width: 140px;">Cantidad</th>
                        <th>Precio</th>
                        <th>SubTotal</th>
                        <th style="width: 90px;">Acción</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>

            <!-- TOTAL -->
            <div class="text-right">
                <h5>Total: <span id="total">0.00</span></h5>
            </div>

            <div class="text-right mt-3">
                <button type="submit" class="btn btn-primary">
                    Finalizar Venta
                </button>
            </div>

        </div>
    </div>

</form>
@section Scripts {
    <script>

        let detalles = [];

        document.addEventListener("DOMContentLoaded", function () {

            let total = 0;

            const producto = document.getElementById("producto");
            const stockInput = document.getElementById("stock");
            const precioInput = document.getElementById("precio");
            const form = document.getElementById("formVenta");

            // ACTUALIZAR PRECIO AL CAMBIAR PRODUCTO
            producto.addEventListener("change", function () {

                let precio = this.selectedOptions[0].dataset.precio;
                let stock = this.selectedOptions[0].dataset.stock;

                precioInput.value = parseFloat(precio).toFixed(2);
                stockInput.value = stock;
            });

            producto.dispatchEvent(new Event("change"));

            
            // AGREGAR PRODUCTO
            
            window.agregar = function () {

                let select = document.getElementById("producto");
                let idProducto = parseInt(select.value);
                let nombre = select.options[select.selectedIndex].text;
                let precio = parseFloat(select.selectedOptions[0].dataset.precio);
                let cantidad = parseInt(document.getElementById("cantidad").value);
                let stock = parseInt(select.selectedOptions[0].dataset.stock);

                if (!cantidad || cantidad <= 0) {
                    alert("Cantidad inválida");
                    return;
                }

                //  VALIDACIÓN STOCK
                if (cantidad > stock) {
                    alert("No hay suficiente stock disponible");
                    return;
                }

                let existente = detalles.find(x => x.idProducto === idProducto);

                if (existente) {

                    // VALIDAR SUMA TOTAL
                    if (existente.cantidad + cantidad > stock) {
                        alert("Supera el stock disponible");
                        return;
                    }

                    existente.cantidad += cantidad;
                    existente.subTotal = existente.cantidad * existente.precio;

                } else {

                    detalles.push({
                        idProducto: idProducto,
                        nombre: nombre,
                        cantidad: cantidad,
                        precio: precio,
                        subTotal: precio * cantidad
                    });
                }

                renderTabla();
            };

            
            // ELIMINAR PRODUCTO
          
            window.eliminar = function (idProducto) {
                detalles = detalles.filter(x => x.idProducto !== idProducto);
                renderTabla();
            };

            
            // EDITAR CANTIDAD 
            
            window.actualizarCantidad = function (idProducto, nuevaCantidad) {

                nuevaCantidad = parseInt(nuevaCantidad);

                let item = detalles.find(x => x.idProducto === idProducto);

                let option = document.querySelector(`#producto option[value='${idProducto}']`);
                let stock = parseInt(option.dataset.stock);

                if (!nuevaCantidad || nuevaCantidad <= 0) {
                    eliminar(idProducto);
                    return;
                }

                // VALIDACIÓN STOCK
                if (nuevaCantidad > stock) {
                    alert("Stock insuficiente");
                    renderTabla();
                    return;
                }

                if (item) {
                    item.cantidad = nuevaCantidad;
                    item.subTotal = item.cantidad * item.precio;
                }

                renderTabla();
            };

            
            // RENDER TABLA
           
            function renderTabla() {

                let tbody = document.querySelector("#tabla tbody");
                tbody.innerHTML = "";

                total = 0;

                detalles.forEach(d => {

                    total += d.subTotal;

                    let fila = `
                        <tr>
                            <td>${d.nombre}</td>
                            <td>
                                <input type="number"
                                       min="1"
                                       class="form-control"
                                       value="${d.cantidad}"
                                       onchange="actualizarCantidad(${d.idProducto}, this.value)" />
                            </td>
                            <td>${d.precio.toFixed(2)}</td>
                            <td>${d.subTotal.toFixed(2)}</td>
                            <td>
                                <button type="button"
                                        class="btn btn-danger btn-sm"
                                        onclick="eliminar(${d.idProducto})">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    `;

                    tbody.innerHTML += fila;
                });

                document.getElementById("total").innerText = total.toFixed(2);
            }

           
            // SUBMIT FORM
          
            if (form) {
                form.onsubmit = function (e) {

                    if (detalles.length === 0) {
                        alert("Debes agregar al menos un producto");
                        e.preventDefault();
                        return false;
                    }

                    document.getElementById("detalleJson").value = JSON.stringify(detalles);

                    return true;
                };
            }

        });

    </script>
}