@model IEnumerable<HotelSol.Models.Habitacion>

<h1>Habitaciones</h1>

<p>
    <a asp-action="Create">Crear nueva habitación</a>
</p>

<table border="1">
    <thead>
        <tr>
            <th>Id</th>
            <th>Número</th>
            <th>Detalle</th>
            <th>Precio</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.IdHabitacion</td>
                <td>@item.Numero</td>
                <td>@item.Detalle</td>
                <td>@item.Precio</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.IdHabitacion">Editar</a>
                </td>
            </tr>
        }
    </tbody>
</table>
