
@{
}
@model HotelSol.Models.Habitacion

<h1>Nueva habitación</h1>

<form asp-action="Create" method="post">

    <div>
        <label>Número</label>
        <input asp-for="Numero" />
    </div>
    <div>
        <label>Detalle</label>
        <input asp-for="Detalle" />
    </div>

    <div>
        <label>Precio</label>
        <input asp-for="Precio" />
    </div>

    <button type="submit">Guardar</button>

</form>

<a asp-action="Index">Volver</a>