@model List<HotelSol.Models.Persona>

@{
    ViewData["Title"] = "Clientes";
}

<h4 class="mb-3">Lista de Clientes</h4>

<div class="card shadow">

    <div class="card-header bg-primary text-white d-flex justify-content-between">
        <span>Lista de Clientes</span>

        <button class="btn btn-success btn-sm"
                onclick="nuevo()">
            Crear Nuevo
        </button>
    </div>

    <div class="card-body">

        <table class="table table-bordered table-hover">

            <thead>
                <tr>
                    <th>Tipo Documento</th>
                    <th>Nro Documento</th>
                    <th>Nombre</th>
                    <th>Apellido</th>
                    <th>Correo</th>
                    <th>Estado</th>
                    <th width="120"></th>
                </tr>
            </thead>

            <tbody>

                @foreach (var x in Model)
                {
                    <tr>
                        <td>@x.TipoDocumento</td>
                        <td>@x.Documento</td>
                        <td>@x.Nombre</td>
                        <td>@x.Apellido</td>
                        <td>@x.Correo</td>

                        <td>
                            @if (x.Estado == true)
                            {
                                <span class="badge badge-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge badge-danger">Inactivo</span>
                            }
                        </td>

                        <td>

                            <button class="btn btn-primary btn-sm"
                                    onclick="editar(@x.IdPersona)">
                                ✏
                            </button>

                            <button class="btn btn-danger btn-sm"
                                    onclick="eliminar(@x.IdPersona)">
                                🗑
                            </button>

                        </td>
                    </tr>
                }

            </tbody>

        </table>

    </div>
</div>

<!-- MODAL -->

<div class="modal fade" id="modalCliente">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5>Cliente</h5>

                <button class="close text-white"
                        data-dismiss="modal">
                    &times;
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="IdPersona" />

                <div class="form-group">
                    <label>Tipo Documento</label>

                    <select id="TipoDocumento" class="form-control">
                        <option>DNI</option>
                        <option>PASAPORTE</option>
                        <option>RUC</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Nro Documento</label>
                    <input id="Documento" class="form-control" />
                </div>

                <div class="form-group">
                    <label>Nombre</label>
                    <input id="Nombre" class="form-control" />
                </div>

                <div class="form-group">
                    <label>Apellido</label>
                    <input id="Apellido" class="form-control" />
                </div>

                <div class="form-group">
                    <label>Correo</label>
                    <input id="Correo" class="form-control" />
                </div>

                <div class="form-group">
                    <label>Estado</label>

                    <select id="Estado" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-dismiss="modal">
                    Cerrar
                </button>

                <button class="btn btn-primary"
                        onclick="guardar()">
                    Guardar
                </button>

            </div>

        </div>
    </div>
</div>

@section Scripts {

    <script>

        function nuevo(){

            limpiar();
            $("#modalCliente").modal("show");
        }

        function limpiar(){

            $("#IdPersona").val(0);
            $("#TipoDocumento").val("DNI");
            $("#Documento").val("");
            $("#Nombre").val("");
            $("#Apellido").val("");
            $("#Correo").val("");
            $("#Estado").val("true");
        }

        function guardar(){

            let data = {

                IdPersona: $("#IdPersona").val(),
                TipoDocumento: $("#TipoDocumento").val(),
                Documento: $("#Documento").val(),
                Nombre: $("#Nombre").val(),
                Apellido: $("#Apellido").val(),
                Correo: $("#Correo").val(),
                Estado: $("#Estado").val()
            };

            $.post("/Cliente/Guardar", data, function(r){

                if(r.ok){
                    location.reload();
                }
            });
        }

        function editar(id){

            $.get("/Cliente/Obtener?id=" + id, function(x){

                $("#IdPersona").val(x.idPersona);
                $("#TipoDocumento").val(x.tipoDocumento);
                $("#Documento").val(x.documento);
                $("#Nombre").val(x.nombre);
                $("#Apellido").val(x.apellido);
                $("#Correo").val(x.correo);
                $("#Estado").val(x.estado.toString());

                $("#modalCliente").modal("show");
            });
        }

        function eliminar(id){

            if(!confirm("Eliminar cliente?")) return;

            $.post("/Cliente/Eliminar", { id }, function(r){

                if(r.ok){
                    location.reload();
                }
            });
        }

    </script>

}
