@model HotelSol.Models.ViewModels.RecepcionIndexVM

@{
    ViewData["Title"] = "Recepción";

    // USAR EL MODELO (NO Query directamente)
    // si no hay fechas usar HOY automáticamente
    var fechaEntrada = (Model.FechaEntrada ?? DateTime.Today).ToString("yyyy-MM-dd");
    var fechaSalida = (Model.FechaSalida ?? DateTime.Today.AddDays(1)).ToString("yyyy-MM-dd");
}

<style>
    .habitacion-card {
        border: 1px solid #dfe6e9;
        border-radius: 6px;
        overflow: hidden;
        background: #fff;
        transition: 0.2s;
    }

        .habitacion-card:hover {
            box-shadow: 0 4px 14px rgba(0,0,0,.08);
            transform: translateY(-2px);
        }

    .habitacion-top {
        padding: 18px;
        min-height: 110px;
    }

    .habitacion-bottom {
        padding: 12px 18px;
        color: #fff;
        font-weight: 700;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .disponible {
        background: #1cc88a;
    }

    .ocupado {
        background: #e74a3b;
    }

    .limpieza {
        background: #36b9cc;
    }

    .link-card {
        text-decoration: none;
        color: inherit;
    }

    .habitacion-bottom.limpieza {
        display: flex;
        flex-direction: column;
        align-items: stretch;
    }

    .text-limpieza {
        color: #36b9cc !important;
        font-weight: 600;
    }
</style>

<!-- FILTRO COMPLETO -->
<div class="card shadow mb-4">
    <div class="card-body">

        <form method="get" asp-action="Index" class="form-inline">

            <!-- PISO -->
            <label class="mr-2 font-weight-bold">Piso</label>
            <select name="pisoId" class="form-control mr-3">
                <option value="">Todos</option>

                @foreach (var piso in Model.Pisos)
                {
                    <option value="@piso.IdPiso"
                            selected="@(Model.PisoSeleccionado == piso.IdPiso)">
                        @piso.Descripcion
                    </option>
                }
            </select>

            <!-- FECHAS -->
            <label class="mr-2 font-weight-bold">Entrada</label>
            <input type="date" name="fechaEntrada"
                   value="@fechaEntrada"
                   class="form-control mr-3" />

            <label class="mr-2 font-weight-bold">Salida</label>
            <input type="date" name="fechaSalida"
                   value="@fechaSalida"
                   class="form-control mr-3" />

            <button type="submit" class="btn btn-primary">
                Buscar disponibilidad
            </button>

        </form>
    </div>
</div>

<!-- TARJETAS -->
<div class="row">
    @foreach (var item in Model.Habitaciones)
    {
        <div class="col-xl-3 col-md-6 mb-4">

            @{
                var bloqueada = item.OcupadaEnFechas;
            }

            @if (item.PuedeReservar && !bloqueada)
            {
                <!-- DISPONIBLE -->
                <a asp-action="Create"
                   asp-route-id="@item.IdHabitacion"
                   asp-route-fechaEntrada="@fechaEntrada"
                   asp-route-fechaSalida="@fechaSalida"
                   class="link-card">

                    <div class="habitacion-card">

                        <div class="habitacion-top">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <h5>NRO: @item.Numero</h5>
                                    <small class="text-success">
                                        CATEGORIA: @item.Categoria
                                    </small>
                                </div>

                                <i class="fas fa-check-circle fa-2x text-success"></i>
                            </div>
                        </div>

                        <div class="habitacion-bottom disponible">
                            <span>DISPONIBLE</span>
                        </div>

                    </div>
                </a>
            }
            else if (bloqueada || item.EstadoCss == "ocupado")
            {
                <!-- OCUPADO / RESERVADO -->
                <a asp-action="Detalle"
                   asp-route-idHabitacion="@item.IdHabitacion"
                   class="link-card">

                    <div class="habitacion-card">

                        <div class="habitacion-top">
                            <div class="d-flex justify-content-between">

                                <div>
                                    <h5>NRO: @item.Numero</h5>

                                    <small class="text-danger">
                                        CATEGORIA: @item.Categoria
                                    </small>
                                </div>

                                @if (bloqueada)
                                {
                                    <i class="fas fa-calendar-times fa-2x text-danger"></i>
                                }
                                else
                                {
                                    <i class="fas fa-bed fa-2x text-danger"></i>
                                }

                            </div>
                        </div>

                        <div class="habitacion-bottom ocupado">
                            <span>
                                @(bloqueada ? "RESERVADA EN FECHAS" : "OCUPADO")
                            </span>
                        </div>

                    </div>
                </a>
            }
            else if (item.EstadoCss == "limpieza")
            {
                <!-- LIMPIEZA -->
                <div class="habitacion-card">

                    <div class="habitacion-top">
                        <div class="d-flex justify-content-between">

                            <div>
                                <h5>NRO: @item.Numero</h5>

                                <small class="text-info">
                                    CATEGORIA: @item.Categoria
                                </small>
                            </div>

                            <i class="fas fa-pump-soap fa-2x text-info"></i>

                        </div>
                    </div>

                    <div class="habitacion-bottom limpieza flex-column">

                        <span class="mb-2">LIMPIEZA</span>

                        <!-- BOTÓN DIRECTO -->
                        <form asp-action="MarcarLimpia" method="post" class="w-100">
                            @Html.AntiForgeryToken()

                            <input type="hidden" name="idHabitacion" value="@item.IdHabitacion" />

                            <button class="btn btn-light btn-sm w-100 text-limpieza">
                                <i class="fa-solid fa-check"></i> Marcar como limpia
                            </button>
                        </form>

                    </div>

                </div>
            }

        </div>
    }
</div>