@model HotelSol.Models.ViewModels.RecepcionIndexVM

@{
    ViewData["Title"] = "Recepción";

    // 🔥 USAR EL MODELO (NO Query directamente)
    var fechaEntrada = Model.FechaEntrada?.ToString("yyyy-MM-dd");
    var fechaSalida = Model.FechaSalida?.ToString("yyyy-MM-dd");
}

<style>
    .habitacion-card {
        border: 1px solid #dfe6e9;
        border-radius: 6px;
        overflow: hidden;
        background: #fff;
        transition: 0.2s;
    }

        .habitacion-card:hover {
            box-shadow: 0 4px 14px rgba(0,0,0,.08);
            transform: translateY(-2px);
        }

    .habitacion-top {
        padding: 18px;
        min-height: 110px;
    }

    .habitacion-bottom {
        padding: 12px 18px;
        color: #fff;
        font-weight: 700;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .disponible {
        background: #1cc88a;
    }

    .ocupado {
        background: #e74a3b;
    }

    .limpieza {
        background: #36b9cc;
    }

    .link-card {
        text-decoration: none;
        color: inherit;
    }
</style>

<!-- 🔥 FILTRO COMPLETO -->
<div class="card shadow mb-4">
    <div class="card-body">

        <form method="get" asp-action="Index" class="form-inline">

            <!-- PISO -->
            <label class="mr-2 font-weight-bold">Piso</label>
            <select name="pisoId" class="form-control mr-3">
                <option value="">Todos</option>

                @foreach (var piso in Model.Pisos)
                {
                    <option value="@piso.IdPiso"
                            selected="@(Model.PisoSeleccionado == piso.IdPiso)">
                        @piso.Descripcion
                    </option>
                }
            </select>

            <!-- 🔥 FECHAS -->
            <label class="mr-2 font-weight-bold">Entrada</label>
            <input type="date" name="fechaEntrada"
                   value="@fechaEntrada"
                   class="form-control mr-3" />

            <label class="mr-2 font-weight-bold">Salida</label>
            <input type="date" name="fechaSalida"
                   value="@fechaSalida"
                   class="form-control mr-3" />

            <button type="submit" class="btn btn-primary">
                Buscar disponibilidad
            </button>

        </form>
    </div>
</div>

<!-- 🔥 TARJETAS -->
<div class="row">
    @foreach (var item in Model.Habitaciones)
    {
        <div class="col-xl-3 col-md-6 mb-4">

            <!-- 🔥 USAMOS DIRECTO item.OcupadaEnFechas -->
            @if (item.PuedeReservar && !item.OcupadaEnFechas)
            {
                <!-- DISPONIBLE -->
                <a asp-action="Create"
                   asp-route-id="@item.IdHabitacion"
                   asp-route-fechaEntrada="@(Model.FechaEntrada?.ToString("yyyy-MM-dd"))"
                   asp-route-fechaSalida="@(Model.FechaSalida?.ToString("yyyy-MM-dd"))"
                   class="link-card">

                    <div class="habitacion-card">

                        <div class="habitacion-top">
                            <h5>NRO: @item.Numero</h5>
                            <small class="text-success">
                                CATEGORIA: @item.Categoria
                            </small>
                        </div>

                        <div class="habitacion-bottom disponible">
                            <span>DISPONIBLE</span>
                            <span><i class="fas fa-angle-right"></i></span>
                        </div>

                    </div>
                </a>
            }
            else
            {
                <!-- 🔴 OCUPADO POR FECHAS -->
                <div class="habitacion-card">

                    <div class="habitacion-top">
                        <h5>NRO: @item.Numero</h5>

                        <small class="text-danger">
                            CATEGORIA: @item.Categoria
                        </small>
                    </div>

                    <div class="habitacion-bottom ocupado">
                        <span>
                            @(item.OcupadaEnFechas ? "RESERVADA EN FECHAS" : item.EstadoTexto)
                        </span>
                    </div>

                </div>
            }

        </div>
    }
</div>