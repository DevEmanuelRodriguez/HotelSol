@@model HotelSol.Models.ViewModels.RecepcionIndexVM

@{
    ViewData["Title"] = "Recepción";

    var fechaEntrada = (Model.FechaEntrada ?? DateTime.Today).ToString("yyyy-MM-dd");
    var fechaSalida = (Model.FechaSalida ?? DateTime.Today.AddDays(1)).ToString("yyyy-MM-dd");
}

<style>
    .habitacion-card {
        border: 1px solid #dfe6e9;
        border-radius: 6px;
        overflow: hidden;
        background: #fff;
        transition: 0.2s;
    }

        .habitacion-card:hover {
            box-shadow: 0 4px 14px rgba(0,0,0,.08);
            transform: translateY(-2px);
        }

    .habitacion-top {
        padding: 18px;
        min-height: 110px;
    }

    .habitacion-bottom {
        padding: 12px 18px;
        color: #fff;
        font-weight: 700;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .disponible {
        background: #1cc88a;
    }

    .ocupado {
        background: #e74a3b;
    }

    .reservada {
        background: #f6c23e;
        color: #212529;
    }

    .limpieza {
        background: #36b9cc;
    }

    .link-card {
        text-decoration: none;
        color: inherit;
    }

    .habitacion-bottom.limpieza,
    .habitacion-bottom.reservada {
        display: flex;
        flex-direction: column;
        align-items: stretch;
    }
</style>

<!-- FILTRO -->
<div class="card shadow mb-4">
    <div class="card-body">

        <form method="get" asp-action="Index" class="form-inline">

            <label class="mr-2 font-weight-bold">Piso</label>

            <select name="pisoId" class="form-control mr-3">
                <option value="">Todos</option>

                @foreach (var piso in Model.Pisos)
                {
                    <option value="@piso.IdPiso"
                            selected="@(Model.PisoSeleccionado == piso.IdPiso)">
                        @piso.Descripcion
                    </option>
                }
            </select>

            <label class="mr-2 font-weight-bold">Entrada</label>
            <input type="date"
                   name="fechaEntrada"
                   value="@fechaEntrada"
                   class="form-control mr-3" />

            <label class="mr-2 font-weight-bold">Salida</label>
            <input type="date"
                   name="fechaSalida"
                   value="@fechaSalida"
                   class="form-control mr-3" />

            <button type="submit" class="btn btn-primary">
                Buscar disponibilidad
            </button>

        </form>

    </div>
</div>

<!-- TARJETAS -->
<div class="row">

    @foreach (var item in Model.Habitaciones)
    {
        <div class="col-xl-3 col-md-6 mb-4">

            @* ================= LIMPIEZA ================= *@
            @if (item.EstadoCss == "limpieza")
            {
                <div class="habitacion-card">

                    <div class="habitacion-top">
                        <div class="d-flex justify-content-between">

                            <div>
                                <h5>NRO: @item.Numero</h5>
                                <small class="text-info">
                                    CATEGORÍA: @item.Categoria
                                </small>
                            </div>

                            <i class="fas fa-pump-soap fa-2x text-info"></i>

                        </div>
                    </div>

                    <div class="habitacion-bottom limpieza flex-column">

                        <span class="mb-2">LIMPIEZA</span>

                        <form asp-action="MarcarLimpia" method="post" class="w-100">
                            @Html.AntiForgeryToken()

                            <input type="hidden"
                                   name="idHabitacion"
                                   value="@item.IdHabitacion" />

                            <button class="btn btn-light btn-sm w-100">
                                <i class="fa-solid fa-check"></i> Limpiar ahora
                            </button>
                        </form>

                    </div>

                </div>
            }

            @* ================= OCUPADA ================= *@
            else if (item.Ocupada)
            {
                <a asp-action="Detalle"
                   asp-route-idHabitacion="@item.IdHabitacion"
                   class="link-card">

                    <div class="habitacion-card">

                        <div class="habitacion-top">
                            <div class="d-flex justify-content-between">

                                <div>
                                    <h5>NRO: @item.Numero</h5>
                                    <small class="text-danger">
                                        CATEGORÍA: @item.Categoria
                                    </small>
                                </div>

                                <i class="fas fa-bed fa-2x text-danger"></i>

                            </div>
                        </div>

                        <div class="habitacion-bottom ocupado">
                            <span>OCUPADA</span>
                        </div>

                    </div>

                </a>
            }

            @* ================= RESERVADA ================= *@
            else if (item.Reservada)
            {
                <div class="habitacion-card">

                    <div class="habitacion-top">
                        <div class="d-flex justify-content-between">

                            <div>
                                <h5>NRO: @item.Numero</h5>
                                <small class="text-warning">
                                    CATEGORÍA: @item.Categoria
                                </small>
                            </div>

                            <i class="fas fa-calendar-check fa-2x text-warning"></i>

                        </div>
                    </div>

                    <div class="habitacion-bottom reservada flex-column">

                        <span class="mb-2">RESERVADA</span>

                        @if (item.PuedeCheckin)
                        {
                            <form asp-action="Checkin" method="post" class="w-100">
                                @Html.AntiForgeryToken()

                                <input type="hidden"
                                       name="idRecepcion"
                                       value="@item.IdRecepcion" />

                                <button class="btn btn-dark btn-sm w-100">
                                    <i class="fa-solid fa-check"></i> Confirmar Check-In
                                </button>
                            </form>
                        }

                        else
                        {
                            <small class="text-dark font-weight-bold">
                                Check-In:
                                @item.FechaReserva?.ToString("dd/MM/yyyy")
                            </small>
                        }

                    </div>

                </div>
            }

            @* ================= DISPONIBLE ================= *@
            else
            {
                <a asp-action="Create"
                   asp-route-id="@item.IdHabitacion"
                   asp-route-fechaEntrada="@fechaEntrada"
                   asp-route-fechaSalida="@fechaSalida"
                   class="link-card">

                    <div class="habitacion-card">

                        <div class="habitacion-top">
                            <div class="d-flex justify-content-between">

                                <div>
                                    <h5>NRO: @item.Numero</h5>
                                    <small class="text-success">
                                        CATEGORÍA: @item.Categoria
                                    </small>
                                </div>

                                <i class="fas fa-check-circle fa-2x text-success"></i>

                            </div>
                        </div>

                        <div class="habitacion-bottom disponible">
                            <span>DISPONIBLE</span>
                        </div>

                    </div>

                </a>
            }

        </div>
    }

</div>