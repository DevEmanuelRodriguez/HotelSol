@model HotelSol.Models.ViewModels.RecepcionIndexVM

@{
    ViewData["Title"] = "Recepción";
}

<style>
    .habitacion-card {
        border: 1px solid #dfe6e9;
        border-radius: 6px;
        overflow: hidden;
        background: #fff;
        transition: 0.2s;
    }

    .habitacion-card:hover {
        box-shadow: 0 4px 14px rgba(0,0,0,.08);
        transform: translateY(-2px);
    }

    .habitacion-top {
        padding: 18px;
        min-height: 110px;
    }

    .habitacion-top h5 {
        font-weight: 700;
        margin-bottom: 4px;
    }

    .habitacion-top small {
        text-transform: uppercase;
        font-weight: 600;
    }

    .habitacion-bottom {
        padding: 12px 18px;
        color: #fff;
        font-weight: 700;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .disponible { background: #1cc88a; }
    .ocupado { background: #e74a3b; }
    .limpieza { background: #36b9cc; }

    .link-card {
        text-decoration: none;
        color: inherit;
    }
</style>

<div class="card shadow mb-4">
    <div class="card-body">
        <form method="get" asp-action="Index" class="form-inline">
            <label class="mr-3 font-weight-bold">Seleccionar Piso</label>
            <select name="pisoId" class="form-control mr-2" style="min-width: 300px;" onchange="this.form.submit()">
                <option value="">Todos</option>
                @foreach (var piso in Model.Pisos)
                {
                    if (Model.PisoSeleccionado == piso.IdPiso)
                    {
                        <option value="@piso.IdPiso" selected>@piso.Descripcion</option>
                    }
                    else
                    {
                        <option value="@piso.IdPiso">@piso.Descripcion</option>
                    }
                }
            </select>
        </form>
    </div>
</div>

<div class="row">
    @foreach (var item in Model.Habitaciones)
    {
        <div class="col-xl-3 col-md-6 mb-4">
            @if (item.PuedeReservar)
            {
                <a asp-action="Create" asp-route-id="@item.IdHabitacion" class="link-card">
                    <div class="habitacion-card">
                        <div class="habitacion-top">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h5>NRO: @item.Numero</h5>
                                    <small class="text-success">CATEGORIA: @item.Categoria</small>
                                </div>
                                <i class="fas fa-shopping-bag fa-2x text-success"></i>
                            </div>
                        </div>
                        <div class="habitacion-bottom @item.EstadoCss">
                            <span>@item.EstadoTexto</span>
                            <span><i class="fas fa-angle-right"></i></span>
                        </div>
                    </div>
                </a>
            }
            else
            {
                <div class="habitacion-card">
                    <div class="habitacion-top">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h5>NRO: @item.Numero</h5>
                                <small class="@(item.EstadoCss == "ocupado" ? "text-danger" : "text-info")">
                                    CATEGORIA: @item.Categoria
                                </small>
                            </div>

                            @if (item.EstadoCss == "ocupado")
                            {
                                <i class="fas fa-bed fa-2x text-danger"></i>
                            }
                            else
                            {
                                <i class="fas fa-pump-soap fa-2x text-info"></i>
                            }
                        </div>
                    </div>
                    <div class="habitacion-bottom @item.EstadoCss">
                        <span>@item.EstadoTexto</span>
                        <span><i class="fas fa-angle-right"></i></span>
                    </div>
                </div>
            }
        </div>
    }
</div>
