@model HotelSol.Models.ViewModels.RecepcionCreateVM

@{
    ViewData["Title"] = "Nueva Recepción";
}

<div class="card shadow mb-3">
    <div class="card-body">
        <h5 class="text-primary font-weight-bold mb-3">Detalles de la Habitación</h5>

        <div class="row">
            <div class="col-md-3">
                <strong>Número:</strong>
                <div>@Model.NumeroHabitacion</div>
            </div>
            <div class="col-md-3">
                <strong>Categoría:</strong>
                <div>@Model.Categoria</div>
            </div>
            <div class="col-md-3">
                <strong>Piso:</strong>
                <div>@Model.Piso</div>
            </div>
            <div class="col-md-3">
                <strong>Detalles:</strong>
                <div>@Model.DetalleHabitacion</div>
            </div>
        </div>
    </div>
</div>

<form asp-action="Create" method="post">

    <input asp-for="IdHabitacion" type="hidden" />
    <input asp-for="IdClienteExistente" type="hidden" id="IdClienteExistente" />

    <!-- PRECIO BASE -->
    <input type="hidden" id="PrecioNoche" value="@Model.PrecioHabitacion" />

    <!-- ERRORES -->
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="card shadow">
        <div class="card-body">
            <div class="row">

                <!-- ================= CLIENTE ================= -->
                <div class="col-md-6">
                    <h5 class="text-primary font-weight-bold mb-3">Detalle Cliente</h5>

                    <label>Nro Documento para buscar:</label>
                    <div class="input-group mb-3">
                        <input asp-for="DocumentoBusqueda" class="form-control" id="DocumentoBusqueda" />
                        <div class="input-group-append">
                            <!-- botón 
                            <button type="button" class="btn btn-success"
                                    data-toggle="modal"
                                    data-target="#modalClientes">
                                Buscar
                            </button>-->
                            <button type="button"
                                    class="btn btn-primary"
                                    onclick="buscarCliente()">
                                Buscar
                            </button>

                        </div>
                    </div>

                    <label>Documento:</label>
                    <input asp-for="Documento" class="form-control mb-3" id="Documento" />

                    <label>Tipo Documento:</label>
                    <select asp-for="TipoDocumento" class="form-control mb-3" id="TipoDocumento">
                        <option value="DNI">DNI</option>
                        <option value="PASAPORTE">Pasaporte</option>
                        <option value="NIE">NIE</option>
                    </select>

                    <label>Nombres:</label>
                    <input asp-for="Nombre" class="form-control mb-3" id="Nombre" />

                    <label>Apellidos:</label>
                    <input asp-for="Apellido" class="form-control mb-3" id="Apellido" />

                    <label>Correo:</label>
                    <input asp-for="Correo" class="form-control mb-3" id="Correo" />
                </div>

                <!-- ================= RESERVA ================= -->
                <div class="col-md-6">
                    <h5 class="text-primary font-weight-bold mb-3">Detalle Reservación</h5>

                    <div class="row">
                        <div class="col-md-6">
                            <label>Fecha Entrada:</label>
                            <input asp-for="FechaEntrada"
                                   asp-format="{0:yyyy-MM-dd}"
                                   id="FechaEntrada"
                                   type="date"
                                   min="@DateTime.Today.ToString("yyyy-MM-dd")"
                                   class="form-control mb-3" />
                        </div>

                        <div class="col-md-6">
                            <label>Fecha Salida:</label>
                            <input asp-for="FechaSalida"
                                   asp-format="{0:yyyy-MM-dd}"
                                   id="FechaSalida"
                                   type="date"
                                   min="@DateTime.Today.ToString("yyyy-MM-dd")"
                                   class="form-control mb-3" />
                        </div>
                    </div>

                    <!-- NOCHES + TEMPORADA -->
                    <div class="row">
                        <div class="col-md-6">
                            <label>Noches:</label>
                            <input type="text" id="Noches" class="form-control mb-3" readonly />
                        </div>

                        <div class="col-md-6">
                            <label>Temporada:</label>
                            <input type="text" id="Temporada" class="form-control mb-3" readonly />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <label>Precio Total:</label>
                            <input asp-for="PrecioInicial" id="PrecioInicial"
                                   class="form-control mb-3" readonly />
                        </div>

                        <div class="col-md-6">
                            <label>Adelanto:</label>
                            <!--  decimal -->
                            <input asp-for="Adelanto"
                                   class="form-control mb-3"
                                   step="0.01"
                                   value="0.00" />
                        </div>
                    </div>

                    <label>Observación:</label>
                    <textarea asp-for="Observacion" class="form-control mb-3" rows="5"></textarea>

                    <div class="text-right">
                        <button type="submit" class="btn btn-primary px-4">Registrar</button>
                    </div>
                </div>

            </div>
        </div>
    </div>
</form>

<!-- ================= MODAL CLIENTES ================= -->
<div class="modal fade" id="modalClientes" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5>Lista de Clientes</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>

            <div class="modal-body">
                @if (Model.Clientes != null && Model.Clientes.Any())
                {
                    <table class="table table-bordered" id="tablaClientes">
                        <thead>
                            <tr>
                                <th></th>
                                <th>Documento</th>
                                <th>Nombre</th>
                                <th>Apellido</th>
                                <th>Correo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model.Clientes)
                            {
                                <tr>
                                    <td>
                                        <button type="button" class="btn btn-primary btn-sm"
                                                onclick="seleccionarCliente(@c.IdPersona, '@c.Documento', '@c.Nombre', '@c.Apellido', '@c.Correo', '@c.TipoDocumento')">
                                            <i class="fa-solid fa-check"></i>
                                        </button>
                                    </td>
                                    <td>@c.Documento</td>
                                    <td>@c.Nombre</td>
                                    <td>@c.Apellido</td>
                                    <td>@c.Correo</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>

        </div>
    </div>
</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // ================= CLIENTE =================
            window.seleccionarCliente = function (id, documento, nombre, apellido, correo, tipoDocumento) {

                document.getElementById("IdClienteExistente").value = id;
                document.getElementById("DocumentoBusqueda").value = documento;
                document.getElementById("Documento").value = documento;
                document.getElementById("Nombre").value = nombre;
                document.getElementById("Apellido").value = apellido;
                document.getElementById("Correo").value = correo;
                document.getElementById("TipoDocumento").value = tipoDocumento || "DNI";

                $('#modalClientes').modal('hide');
            };

            // ================= PRECIO + TEMPORADA =================
            function obtenerMultiplicador(fecha) {
                let mes = fecha.getMonth() + 1;

                if (mes >= 6 && mes <= 8)
                    return { mult: 1.5, nombre: "ALTA 🔴" };

                if (mes == 1 || mes == 2)
                    return { mult: 0.8, nombre: "BAJA 🟢" };

                return { mult: 1, nombre: "MEDIA 🟡" };
            }

            //Funcion buscar cliente
            window.buscarCliente = function () {

            let doc = document.getElementById("DocumentoBusqueda").value;

            fetch('/Recepcion/BuscarCliente?documento=' + doc)
                .then(response => response.json())
                .then(data => {

                    let tbody = document.querySelector("#tablaClientes tbody");
                    tbody.innerHTML = "";

                    data.forEach(c => {

                        tbody.innerHTML += `
                        <tr>
                            <td>
                            <button type="button"
                                class="btn btn-primary btn-sm"
                                onclick="seleccionarCliente(
                                ${c.idPersona},
                                '${c.documento}',
                                '${c.nombre}',
                                '${c.apellido}',
                                '${c.correo}',
                                '${c.tipoDocumento}'
                            )">✔</button>
                            </td>
                            <td>${c.documento}</td>
                            <td>${c.nombre}</td>
                            <td>${c.apellido}</td>
                            <td>${c.correo}</td>
                        </tr>`;
                    });

                    $('#modalClientes').modal('show');
                });
        }

            function calcularTotal() {

                let entrada = document.getElementById("FechaEntrada").value;
                let salida = document.getElementById("FechaSalida").value;
                let precio = parseFloat(document.getElementById("PrecioNoche").value);

                if (!entrada || !salida) return;

                let f1 = new Date(entrada);
                let f2 = new Date(salida);

                if (f2 <= f1) {
                    document.getElementById("PrecioInicial").value = "";
                    document.getElementById("Noches").value = "";
                    document.getElementById("Temporada").value = "";
                    return;
                }

                let dias = (f2 - f1) / (1000 * 60 * 60 * 24);

                let total = 0;
                let temporada = "";

                for (let i = 0; i < dias; i++) {
                    let fecha = new Date(f1);
                    fecha.setDate(f1.getDate() + i);

                    let temp = obtenerMultiplicador(fecha);
                    total += precio * temp.mult;

                    if (i === 0) temporada = temp.nombre;
                }

                document.getElementById("PrecioInicial").value = total.toFixed(2);
                document.getElementById("Noches").value = dias;
                document.getElementById("Temporada").value = temporada;
            }

            document.getElementById("FechaEntrada").addEventListener("change", calcularTotal);
            document.getElementById("FechaSalida").addEventListener("change", calcularTotal);
            //  SOLUCIÓN CLAVE
            calcularTotal();
        });
    </script>
}